{
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/vendor/**": true,
    "**/.git/**": true,
    "**/storage/**": true,
    "**/dist/**": true,
    "**/.next/**": true,
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/vendor": true,
  },
  "editor.minimap.enabled": false,
  "files.trimTrailingWhitespace": true,
  "extensions.autoUpdate": false,
  "editor.lineHeight": 26,
  "intelephense.files.exclude": ["**/node_modules/**", "**/storage/**"],
  "git.autofetch": false,
  "git.enableSmartCommit": false,
  "editor.smoothScrolling": false,
  "extensions.autoCheckUpdates": false,
  "workbench.iconTheme": "vscode-icons",
  "gitlens.ai.model": "vscode",
  "gitlens.ai.vscode.model": "copilot:gpt-4.1",
  "github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "markdown": true,
    "scminput": false,
  },
  "errorLens.alignMessage": {
    "start": 0,
    "end": 0,
    "minimumMargin": 4,
    "padding": [0, 0],
    "useFixedPosition": true,
  },
  "errorLens.followCursor": "closestProblem",
  "errorLens.gutterIconsEnabled": true,
  "errorLens.enabled": true,
  "files.associations": { "*.module": "php" },
  "intelephense.files.maxSize": 5000000,
  "intelephense.environment.phpVersion": "8.4.0",
  "intelephense.environment.includePaths": [
    "vendor",
    "src/vendor",
    "**vendor**",
  ],
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "editor.rulers": [90, 120],
  // "editor.formatOnSave": true,
  "editor.formatOnSaveMode": "modifications",
  "terminal.integrated.fontFamily": "JetBrains Mono NL",
  "editor.fontFamily": "JetBrains Mono NL",
  "editor.fontLigatures": true,
  "terminal.integrated.fontSize": 13,
  "terminal.integrated.lineHeight": 1.2,
  "update.showReleaseNotes": false,
  "update.mode": "none",
  // "editor.formatOnPaste": true,
  "Laravel.phpCommand": "/opt/homebrew/bin/php",
  "php.validate.executablePath": "/opt/homebrew/bin/php",
  "chat.unifiedAgentsBar.enabled": true,
  "workbench.secondarySideBar.defaultVisibility": "hidden",
  "[php]": {
    "editor.formatOnSave": false,
    "editor.defaultFormatter": "bmewburn.vscode-intelephense-client",
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "workbench.editor.wrapTabs": true,
  "chat.viewSessions.orientation": "stacked",
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[scss]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "http.systemCertificatesNode": true,
  "geminicodeassist.project": "gen-lang-client-0710813416",
  "[css]": {
    "editor.defaultFormatter": "sibiraj-s.vscode-scss-formatter",
  },
  "[vue]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "vim.easymotion": true,
  "vim.incsearch": true,
  "vim.useSystemClipboard": true,
  "vim.useCtrlKeys": true,
  "vim.hlsearch": true,
  "vim.insertModeKeyBindings": [
    {
      "before": ["j", "j"],
      "after": ["<Esc>"],
    },
  ],
  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": ["<leader>", "d"],
      "after": ["d", "d"],
    },
    {
      "before": ["<C-n>"],
      "commands": [":nohl"],
    },
    {
      "before": ["K"],
      "commands": ["lineBreakInsert"],
      "silent": true,
    },
  ],
  "vim.leader": "<space>",
  "vim.handleKeys": {
    "<C-a>": false,
    "<C-f>": false,
  },
  // To improve performance
  "extensions.experimental.affinity": {
    "vscodevim.vim": 1,
  },
  "security.workspace.trust.untrustedFiles": "open",
  "workbench.activityBar.location": "top",
  // "diffEditor.ignoreTrimWhitespace": false,
}
